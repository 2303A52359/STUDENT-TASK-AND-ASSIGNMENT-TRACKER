<header class="topbar topbar-user">
  <button class="menu-toggle" type="button" data-menu-toggle>
    Menu
  </button>

  <div class="workspace-pill">
    <span class="workspace-dot"></span>
    <span>Student Productivity Workspace</span>
  </div>

  <div class="notification-panel">
    <div class="notification-panel-header">
      <strong>Messages</strong>
      <span class="notification-badge"><%= unreadNotificationCount %></span>
    </div>
    <% if (notifications && notifications.length) { %>
      <div class="notification-list">
        <% notifications.forEach((notification) => { %>
          <a href="<%= notification.link || '#' %>" class="notification-item <%= notification.readAt ? '' : 'notification-item-unread' %>">
            <strong><%= notification.title %></strong>
            <span><%= notification.message %></span>
          </a>
        <% }) %>
      </div>
    <% } else { %>
      <div class="notification-empty">No messages yet.</div>
    <% } %>
  </div>

  <div class="topbar-user">
    <img src="<%= currentUser.profilePic %>" alt="Profile" class="avatar avatar-small" />
    <div>
      <strong><%= currentUser.name %></strong>
      <p>Personal tracking account</p>
    </div>
  </div>
</header>
