<%- include('../partials/user-shell-start', { title, currentUser, currentPath }) %>
<section class="page-header page-header-inline">
  <div>
    <p class="tag">Task Management</p>
    <h1>Create Task</h1>
    <p class="muted">Add a new task and track it by subject, deadline, and priority.</p>
  </div>
  <a href="/tasks" class="button secondary">Back</a>
</section>

<section class="card">
  <form action="/tasks" method="POST" enctype="multipart/form-data" class="form-grid two-columns">
    <label>
      Task Title
      <input type="text" name="title" placeholder="Example: Revise chapter 2" required />
    </label>

    <label>
      Subject
      <input type="text" name="subject" placeholder="Example: Mathematics" required />
    </label>

    <label>
      Deadline
      <input type="datetime-local" name="deadline" required />
    </label>

    <label>
      Priority
      <select name="priority" required>
        <option value="High">High</option>
        <option value="Medium" selected>Medium</option>
        <option value="Low">Low</option>
      </select>
    </label>

    <label>
      Status
      <select name="status" required>
        <option value="Pending" selected>Pending</option>
        <option value="Completed">Completed</option>
      </select>
    </label>

    <label class="full-width">
      Description
      <textarea name="description" rows="5" placeholder="Add notes for this task"></textarea>
    </label>

    <label class="full-width">
      Attachment (Optional)
      <input type="file" name="file" accept=".pdf,image/*" />
    </label>

    <div class="full-width form-actions">
      <button type="submit" class="button">Create Task</button>
      <a href="/tasks" class="button secondary">Cancel</a>
    </div>
  </form>
</section>
<%- include('../partials/user-shell-end') %>
