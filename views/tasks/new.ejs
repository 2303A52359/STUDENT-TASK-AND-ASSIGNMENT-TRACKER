<%- include('../partials/user-shell-start', { title, currentUser, currentPath }) %>
<section class="page-header page-header-inline">
  <div>
    <p class="tag">Assignment Management</p>
    <h1>Create Assignment</h1>
    <p class="muted">Add complete assignment details with subject, class, deadline, and attachment.</p>
  </div>
  <a href="<%= basePath %>" class="button secondary">Back</a>
</section>

<section class="card">
  <form action="<%= basePath %>" method="POST" enctype="multipart/form-data" class="form-grid two-columns">
    <label>
      Assignment Title
      <input type="text" name="title" placeholder="Example: Chapter 4 Lab Report" required />
    </label>

    <label>
      Subject
      <input type="text" name="subject" placeholder="Example: Science" required />
    </label>

    <label>
      Course or Class
      <input type="text" name="course" placeholder="Example: Grade 10 Physics" />
    </label>

    <label>
      Deadline
      <input type="datetime-local" name="deadline" required />
    </label>

    <label>
      Assignment Type
      <select name="assignmentType" required>
        <option value="Assignment" selected>Assignment</option>
        <option value="Homework">Homework</option>
        <option value="Project">Project</option>
        <option value="Exam Prep">Exam Prep</option>
        <option value="Notes">Notes</option>
        <option value="Presentation">Presentation</option>
      </select>
    </label>

    <label>
      Priority
      <select name="priority" required>
        <option value="High">High</option>
        <option value="Medium" selected>Medium</option>
        <option value="Low">Low</option>
      </select>
    </label>

    <label>
      Status
      <select name="status" required>
        <option value="Pending" selected>Pending</option>
        <option value="Completed">Completed</option>
      </select>
    </label>

    <label class="full-width">
      Description
      <textarea name="description" rows="5" placeholder="Add extra details for the assignment"></textarea>
    </label>

    <label class="full-width">
      Attachment (PDF or image)
      <input type="file" name="file" accept=".pdf,image/*" />
    </label>

    <div class="full-width form-actions">
      <button type="submit" class="button">Create Assignment</button>
      <a href="<%= basePath %>" class="button secondary">Cancel</a>
    </div>
  </form>
</section>
<%- include('../partials/user-shell-end') %>
