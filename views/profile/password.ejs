<%- include('../partials/user-shell-start', { title, currentUser, currentPath }) %>
<section class="page-header page-header-inline">
  <div>
    <p class="tag">Security</p>
    <h1>Change Password</h1>
    <p class="muted">Verify your current password before saving a new one.</p>
  </div>
  <a href="/profile" class="button secondary">Back to Profile</a>
</section>

<section class="card">
  <form action="/profile/password?_method=PUT" method="POST" class="form-grid">
    <label>
      Current Password
      <input type="password" name="currentPassword" required />
    </label>

    <label>
      New Password
      <input type="password" name="newPassword" minlength="6" required />
    </label>

    <label>
      Confirm New Password
      <input type="password" name="confirmPassword" minlength="6" required />
    </label>

    <button type="submit" class="button">Update Password</button>
  </form>
</section>
<%- include('../partials/user-shell-end') %>
