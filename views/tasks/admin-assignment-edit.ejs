<%- include('../partials/admin-shell-start', { title, currentUser, currentPath }) %>
<section class="page-header page-header-inline">
  <div>
    <p class="tag">Administration</p>
    <h1>Edit Assignment</h1>
    <p class="muted">Adjust assignment details and reassign it to a different user if needed.</p>
  </div>
  <a href="/manage-assignments/<%= task._id %>" class="button secondary">Back to Details</a>
</section>

<section class="card">
  <form action="/manage-assignments/<%= task._id %>?_method=PUT" method="POST" enctype="multipart/form-data" class="form-grid two-columns">
    <label>
      Assignment Title
      <input type="text" name="title" value="<%= task.title %>" required />
    </label>

    <label>
      Subject
      <input type="text" name="subject" value="<%= task.subject || '' %>" required />
    </label>

    <label>
      Course or Class
      <input type="text" name="course" value="<%= task.course || '' %>" />
    </label>

    <label>
      Deadline
      <input type="datetime-local" name="deadline" value="<%= new Date(task.deadline).toISOString().slice(0, 16) %>" required />
    </label>

    <label>
      Assignment Type
      <select name="assignmentType" required>
        <option value="Assignment" <%= task.assignmentType === 'Assignment' ? 'selected' : '' %>>Assignment</option>
        <option value="Homework" <%= task.assignmentType === 'Homework' ? 'selected' : '' %>>Homework</option>
        <option value="Project" <%= task.assignmentType === 'Project' ? 'selected' : '' %>>Project</option>
        <option value="Exam Prep" <%= task.assignmentType === 'Exam Prep' ? 'selected' : '' %>>Exam Prep</option>
        <option value="Notes" <%= task.assignmentType === 'Notes' ? 'selected' : '' %>>Notes</option>
        <option value="Presentation" <%= task.assignmentType === 'Presentation' ? 'selected' : '' %>>Presentation</option>
      </select>
    </label>

    <label>
      Priority
      <select name="priority" required>
        <option value="High" <%= task.priority === 'High' ? 'selected' : '' %>>High</option>
        <option value="Medium" <%= task.priority === 'Medium' ? 'selected' : '' %>>Medium</option>
        <option value="Low" <%= task.priority === 'Low' ? 'selected' : '' %>>Low</option>
      </select>
    </label>

    <label>
      Status
      <select name="status" required>
        <option value="Pending" <%= !task.completed ? 'selected' : '' %>>Pending</option>
        <option value="Completed" <%= task.completed ? 'selected' : '' %>>Completed</option>
      </select>
    </label>

    <label>
      Assign To
      <select name="assignedTo" required>
        <% users.forEach((user) => { %>
          <option value="<%= user._id %>" <%= task.assignedTo && task.assignedTo.toString() === user._id.toString() ? 'selected' : '' %>><%= user.name %> (<%= user.email %>)</option>
        <% }) %>
      </select>
    </label>

    <label class="full-width">
      Description
      <textarea name="description" rows="5"><%= task.description %></textarea>
    </label>

    <label class="full-width">
      Replace Attachment
      <input type="file" name="file" accept=".pdf,image/*" />
      <% if (task.file) { %>
        <span class="muted small-text">Current file: <a href="<%= task.file %>" target="_blank" rel="noreferrer">Open current attachment</a></span>
      <% } %>
    </label>

    <div class="full-width form-actions">
      <button type="submit" class="button">Save Changes</button>
      <a href="/manage-assignments/<%= task._id %>" class="button secondary">Cancel</a>
    </div>
  </form>
</section>
<%- include('../partials/admin-shell-end') %>
